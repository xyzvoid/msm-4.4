# eBPF defconfig fragment for Android 4.4.205 (msm-4.4)
# Usage: scripts/kconfig/merge_config.sh <base_defconfig> bpf.config

# --- eBPF core ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=n
CONFIG_HAVE_BPF_JIT=y
CONFIG_BPF_EVENTS=y

# --- eBPF map types ---
CONFIG_BPF_STREAM_PARSER=y

# --- cgroup / socket BPF ---
CONFIG_CGROUP_BPF=y
CONFIG_SOCK_CGROUP_DATA=y
CONFIG_NET_CLS_BPF=m
CONFIG_NET_ACT_BPF=m

# --- perf / tracing ---
CONFIG_PERF_EVENTS=y
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBES=y
CONFIG_UPROBE_EVENTS=y
CONFIG_TRACING=y
CONFIG_FTRACE=y

# --- debug info (needed by verifier) ---
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_BTF=n
