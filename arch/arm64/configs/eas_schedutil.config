# EAS + schedutil defconfig fragment for Android 4.4.205 (msm-4.4)
# Usage: scripts/kconfig/merge_config.sh <base_defconfig> eas_schedutil.config

CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_INTERACTIVE is not set
# CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND is not set

CONFIG_SCHED_EAS=y
CONFIG_SCHED_EAS_ENERGY_MARGIN_PCT=5
CONFIG_SCHED_MC=y
CONFIG_SCHED_SMT=y
CONFIG_SCHED_DEBUG=y
CONFIG_HZ=300
CONFIG_IRQ_WORK=y
# CONFIG_SCHED_WALT is not set
